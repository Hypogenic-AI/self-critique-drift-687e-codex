{"type":"item.started","item":{"id":"item_50","type":"command_execution","command":"/usr/bin/bash -lc \"pwd && source .venv/bin/activate && python - <<'PY'\nimport pandas as pd, numpy as np, json\nfrom pathlib import Path\np=Path('results/evaluations/example_level_results.csv')\ndf=pd.read_csv(p)\nprint('n',len(df))\nprint('\\\\nBy dataset accuracy:')\nfor d,g in df.groupby('dataset'):\n    print(d, 'baseline', g.baseline_correct.mean(), 'redecode', g.redecode_correct.mean(), 'self', g.self_revised_correct.mean())\n\n# transitions baseline->self\nimproved=((df.baseline_correct==0)&(df.self_revised_correct==1)).sum()\ndegraded=((df.baseline_correct==1)&(df.self_revised_correct==0)).sum()\nunchanged=((df.baseline_correct==df.self_revised_correct)).sum()\nprint('\\\\nTransitions baseline->self', {'improved':int(improved),'degraded':int(degraded),'unchanged':int(unchanged)})\n\n# external subset\nex=df[df.external_revised_correct.notna()].copy()\nprint('\\\\nExternal subset n',len(ex))\nprint('baseline',ex.baseline_correct.mean(),'self',ex.self_revised_correct.mean(),'external',ex.external_revised_correct.mean())\nprint('ext improved', int(((ex.baseline_correct==0)&(ex.external_revised_correct==1)).sum()))\nprint('ext degraded', int(((ex.baseline_correct==1)&(ex.external_revised_correct==0)).sum()))\n\n# layer aggregated top/bottom\ncos=pd.read_csv('results/evaluations/layer_drift_summary.csv')\nfor cond in ['redecode','self_critique','external_critique']:\n    c=cos[cos.condition==cond].sort_values('layer')\n    if len(c):\n        print('\\\\n',cond,'early mean',c[c.layer<=8]['mean'].mean(),'late mean',c[c.layer>20]['mean'].mean())\n\n# count corrected examples for probe\nprint('\\\\ncorrected count', int(df.was_corrected_by_self.sum()), 'remained wrong', int(df.remained_wrong_after_self.sum()))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
