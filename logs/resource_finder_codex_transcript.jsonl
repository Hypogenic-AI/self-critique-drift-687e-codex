{"type":"item.started","item":{"id":"item_23","type":"command_execution","command":"/usr/bin/bash -lc \"pwd\nsource .venv/bin/activate\npython - << 'PY'\nimport arxiv\nqueries=[\n 'large language model self-reflection reasoning',\n 'large language model self-correction',\n 'large language model residual stream representation',\n 'activation steering large language models',\n 'linear probe transformer reasoning',\n 'language model internal representations reasoning'\n]\nseen=set(); rows=[]\nfor q in queries:\n    search=arxiv.Search(query=q,max_results=25,sort_by=arxiv.SortCriterion.Relevance)\n    for r in search.results():\n        if r.entry_id in seen: continue\n        seen.add(r.entry_id)\n        rows.append({\n          'id':r.get_short_id(),\n          'title':r.title.strip().replace('\\\\n',' '),\n          'year':r.published.year,\n          'authors':', '.join(a.name for a in r.authors[:3]),\n          'pdf':r.pdf_url,\n          'entry':r.entry_id,\n        })\nrows=sorted(rows,key=lambda x:(-x['year'],x['id']))\nprint('total',len(rows))\nfor i,r in enumerate(rows[:120],1):\n    print(f\\\"{i:02d}|{r['year']}|{r['id']}|{r['title']}|{r['pdf']}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
