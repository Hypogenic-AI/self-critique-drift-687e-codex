{"type":"item.started","item":{"id":"item_36","type":"command_execution","command":"/usr/bin/bash -lc \"pwd\nsource .venv/bin/activate\npython - << 'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\nbase=Path('datasets')\nbase.mkdir(exist_ok=True)\n\nspecs=[\n ('gsm8k','main','gsm8k'),\n ('commonsense_qa',None,'commonsense_qa'),\n ('truthful_qa','multiple_choice','truthful_qa_multiple_choice'),\n]\nsummary=[]\nfor name,config,out in specs:\n    print('loading',name,config)\n    ds=load_dataset(name,config) if config else load_dataset(name)\n    outdir=base/out\n    ds.save_to_disk(str(outdir))\n    info={k:len(v) for k,v in ds.items()}\n    rec={\n      'dataset':name,\n      'config':config,\n      'outdir':str(outdir),\n      'splits':info,\n      'features':{k:str(v.features) for k,v in ds.items()}\n    }\n    # sample from first split\n    first_split=next(iter(ds.keys()))\n    sample=ds[first_split][:5]\n    (outdir/'samples').mkdir(exist_ok=True)\n    with open(outdir/'samples'/'samples.json','w') as f:\n        json.dump(sample,f,indent=2)\n    summary.append(rec)\n\nwith open(base/'dataset_summary.json','w') as f:\n    json.dump(summary,f,indent=2)\nprint('done',len(summary))\nfor s in summary:\n    print(s['dataset'],s['config'],s['splits'],s['outdir'])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
